OPENAI_MODEL=gpt-4.1
OPENAI_MODEL_MINI=gpt-4.1-mini
OPENAI_MODEL_EXTRACTION=gpt-4.1-mini
OPENAI_MODEL_GENERATION=gpt-4.1
LLM_CONTEXT_SWITCH_TOKENS=20000
LLM_MOCK=false
MAX_UPLOAD_MB=10
APP_LOG_LEVEL=INFO

# Em producao, ajuste para o dominio final, ex. https://seu-dominio.com
FRONTEND_ORIGIN=http://localhost,http://127.0.0.1

# Usado no build do frontend (Vite). Em producao com nginx do compose, mantenha /api.
VITE_API_BASE_URL=/api
